# 키움 REST API (Phase 0에서는 존재 검증만 — 더미값이어도 기동됨)
KIWOOM_APP_KEY=your-app-key
KIWOOM_SECRET_KEY=your-secret-key
KIWOOM_MOCK=true

# PostgreSQL
POSTGRES_PASSWORD=ohmystock

# 네이버 검색 오픈 API (선택 — 미설정 시 뉴스 수집을 생략하고 진행)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 쓰기 엔드포인트(/collect,/score,/analyze) 보호용 API 키 (선택 — 미설정 시
# 경고만 남기고 허용, 실전 전환 시 필수) (반드시 고유 값으로 변경)
API_WRITE_TOKEN=your-write-token

# CORS 허용 오리진 (콤마 구분)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── P6 스케줄러(데일리 타임라인 자동화 — 결정 #37~#40) ─────────────────
# 기본 true: 거래일마다 수집 19:00 → 스코어링 → 분석 08:20 → 트레이딩
# 09:00 자동 기동(완전 자동매매 — 결정 #39). false = 영속 off.
# ⚠️ /schedule/pause는 인메모리(재기동 시 enabled 복귀) — **지속 정지는
# 반드시 이 값(false)으로**(스펙 §10-3·§10-5).
# ⚠️ 이 값은 프로세스 기동 시 1회만 읽힌다(get_settings lru_cache) —
# **변경 후 반드시 `docker compose up -d backend`(재시작)로 적용**할 것.
# 파일만 고치면 실행 중 스케줄러는 조용히 이전 값으로 계속 동작한다
# (트레이더 T7a — 조용한 실패 모드).
# ⚠️ 반일장/개장시각 변경일(수능일 등)은 캘린더가 모른다 — 알려진 날은
# 전일에 SCHEDULER_ENABLED=false+재시작으로 우회하고, **다음 거래일 수집
# 창(19:00) 이전에 true+재시작으로 복귀**할 것(잊으면 자동매매 무기한
# 정지 — 스펙 §10-5 운영 절차).
# 리플레이 프로필(KIWOOM_BASE_URL_OVERRIDE 설정 시)에서는 이 값과 무관하게
# 스케줄러 미기동.
SCHEDULER_ENABLED=true

# ── 리플레이 프로필(장외 검증 — 스펙 §4-1) ──────────────────────────────
# ⚠️ 리플레이 테스트가 끝나면 override를 반드시 주석 처리/삭제할 것 —
# 남겨두면 다음 기동에서 backend가 리플레이 서버 미도달로 기동을 거부한다
# (fail-loud 게이트 — 조용히 로컬 목을 바라보는 상태는 구조적으로 없음).
# 허용 호스트: 127.0.0.1 / localhost / replay(컨테이너 네트워크 한정).
# 재생 앵커는 backend가 기동 시 /_replay/status에서 자동 취득(SSOT — 별도
# 앱 변수 없음). 서버 미도달·REPLAY_SPEED≠1.0이면 backend가 기동을 거부.
# KIWOOM_BASE_URL_OVERRIDE=http://127.0.0.1:9095
# 리플레이 컨테이너용(--profile replay): REPLAY_ANCHOR는 목 서버의 재생
# 기준 시각(필수), 배속≠1.0 런은 Task 8 근거 사용 금지(§5).
# REPLAY_ANCHOR=2026-07-10T09:00:00
# REPLAY_SPEED=1.0
